#!/bin/bash


if [[ "${ASK_API_URL:-}" == "" ]]; then
  echo "Error: ASK_API_URL is not set."
  exit 1
fi

if [[ "${ASK_MODEL:-}" == "" ]]; then
  echo "Error: ASK_MODEL is not set."
  exit 1
fi

if [[ "${ASK_API_KEY:-}" == "" ]]; then
  echo "Error: ASK_API_KEY is not set."
  exit 1
fi

USER_PROMPT=""
if [[ ! -t 0 ]]; then
  USER_PROMPT=$(cat)
fi

if [[ "$#" -gt 0 ]]; then
  if [[ -n "$USER_PROMPT" ]]; then
    USER_PROMPT="$USER_PROMPT, $*"
  else
    USER_PROMPT="$*"
  fi
fi

if [[ -z "$USER_PROMPT" ]]; then
  echo "Error: No prompt provided."
  exit 1
fi

REQUEST_BODY=$(
  jq -n \
    --arg model "$ASK_MODEL" \
    --arg prompt "$USER_PROMPT" \
    '{
      model: $model,
      messages: [
        {
          role: "system",
          content: "You are a CLI tool. Output plain text only. No yapping. Keep the output concise."
        },
        {
          role: "user",
          content: $prompt
        }
      ]
    }'
)

RESPONSE=$(curl "$ASK_API_URL" -s -w "\n%{http_code}" \
-H "Content-Type: application/json" \
-H "Authorization: Bearer $ASK_API_KEY" \
-d "$REQUEST_BODY")

if [[ $? != 0 ]]; then
  echo "Error: Failed to connect to the API."
  exit 1
fi

HTTP_STATUS=$(echo "$RESPONSE" | egrep '^[0-9]{3}')
BODY=$(echo "$RESPONSE" | sed '/^$/,$d')

if ! echo "$BODY" | jq . > /dev/null 2>&1; then
  echo "Error: Invalid JSON response."
  exit 1
fi


if [[ "$HTTP_STATUS" == "200" ]]; then
  echo "$BODY" | jq -r 'if .error then .error.message else .choices[0].message.content end'
else
  echo "Error: HTTP Status Code $HTTP_STATUS"
  echo "$BODY" | jq -r '.error.message // .message // .error_description // .detail // .'
fi
