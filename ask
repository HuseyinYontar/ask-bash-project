#!/bin/bash


if [[ "$ASK_API_URL" == "" ]]; then
  echo "Error: ASK_API_URL is not set."
  exit 1
fi

if [[ "$ASK_MODEL" == "" ]]; then
  echo "Error: ASK_MODEL is not set."
  exit 1
fi

if [[ "$ASK_API_KEY" == "" ]]; then
  echo "Error: ASK_API_KEY is not set."
  exit 1
fi


curl "$ASK_API_URL" \
-H "Content-Type: application/json" \
-H "Authorization: Bearer $ASK_API_KEY" \
-d '{
	"model": "llama-3.3-70b-versatile",
	"messages": [
	{
		"role": "system",
		"content": "You are a CLI tool. Output plain text only. No yapping. Keep the output concise."
	},
	{
		"role": "user",
		"content": "Explain the importance of fast language models"
	}]
}'
